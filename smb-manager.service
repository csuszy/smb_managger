[Unit]
Description=SambaHub NAS Administration Web Interface
After=network.target smbd.service nmbd.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/smb-manager
ExecStart=/usr/bin/node /opt/smb-manager/server.js
Restart=always
RestartSec=5
Environment=NODE_ENV=production PORT=8080

[Install]
WantedBy=multi-user.target
